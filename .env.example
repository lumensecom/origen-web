# Supabase — obtén estos valores en:
# Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://<tu-project-id>.supabase.co
VITE_SUPABASE_ANON_KEY=<tu-anon-public-key>

# Anthropic — obtén tu key en:
# console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-...

# Supabase service role — solo para Vercel (funciones serverless).
# Dashboard → Project Settings → API → service_role (secret). NUNCA expongas esta clave al navegador.
SUPABASE_SERVICE_ROLE_KEY=<tu-service-role-key>
